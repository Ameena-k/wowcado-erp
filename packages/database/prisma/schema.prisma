datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleType {
  ADMIN
  USER
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  MANAGE
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userRoles UserRole[]
  auditLogs AuditLog[]
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  type        RoleType @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  userRoles   UserRole[]
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  action      PermissionAction
  resource    String
  description String?
  createdAt   DateTime         @default(now())

  rolePermissions RolePermission[]

  @@unique([action, resource])
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  action    String
  resource  String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model TaxRate {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  rate      Decimal  @db.Decimal(5, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model ExpenseCategory {
  id                String    @id @default(uuid()) @db.Uuid
  name              String    @unique
  linkedAccountCode String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  Expense           Expense[]
}

model Product {
  id                String  @id @default(uuid()) @db.Uuid
  sku               String  @unique
  name              String
  categoryId        String  @db.Uuid
  unit              String
  sellingPrice      Decimal @db.Decimal(10, 2)
  taxRateId         String  @db.Uuid
  active            Boolean @default(true)
  description       String?
  type              String  @default("GOODS") // GOODS or SERVICES
  hsnSacCode        String?
  salesAccountId    String? @db.Uuid
  purchaseAccountId String? @db.Uuid

  category        Category @relation(fields: [categoryId], references: [id])
  taxRate         TaxRate  @relation(fields: [taxRateId], references: [id])
  salesAccount    Account? @relation("ProductSalesAccount", fields: [salesAccountId], references: [id])
  purchaseAccount Account? @relation("ProductPurchaseAccount", fields: [purchaseAccountId], references: [id])

  orderItems   OrderItem[]
  invoiceItems InvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id              String       @id @default(uuid()) @db.Uuid
  name            String
  phone           String       @unique
  email           String?      @unique
  status          RecordStatus @default(ACTIVE)
  notes           String?
  gstin           String?      @unique
  pan             String?
  stateCode       String?      // GST State Code e.g. "32" for Kerala
  isGstRegistered Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  addresses        CustomerAddress[]
  orders           Order[]
  invoices         Invoice[]
  payments         CustomerPayment[]
  whatsappMessages WhatsappMessageLog[]
}

model Society {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @unique
  areaOrLocality String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  addresses CustomerAddress[]
}

model Vendor {
  id              String          @id @default(uuid()) @db.Uuid
  name            String
  phone           String?
  email           String?
  address         String?
  notes           String?
  status          RecordStatus    @default(ACTIVE)
  gstin           String?         @unique
  pan             String?
  stateCode       String?         // GST State Code
  isGstRegistered Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  Expense         Expense[]
  SupplierBill    SupplierBill[]
  VendorPayment   VendorPayment[]
}

model CustomerAddress {
  id            String   @id @default(uuid()) @db.Uuid
  customerId    String   @db.Uuid
  societyId     String   @db.Uuid
  label         String?
  recipientName String
  phone         String
  blockOrStreet String
  doorNo        String
  landmark      String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  society  Society  @relation(fields: [societyId], references: [id])
  orders   Order[]
}

model DeliveryZone {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  pincode            String
  active             Boolean  @default(true)
  deliveryCharge     Decimal  @db.Decimal(10, 2)
  minimumOrderAmount Decimal? @db.Decimal(10, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  orders Order[]
}

model DeliverySlot {
  id          String   @id @default(uuid()) @db.Uuid
  name        String // Generic grouping like "Morning"
  displayName String
  startTime   DateTime @db.Time
  endTime     DateTime @db.Time
  active      Boolean  @default(true)
  sortOrder   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]
}

enum OrderStatus {
  DRAFT
  PLACED
  CONFIRMED
  PACKED
  DISPATCHED
  DELIVERED
  CANCELLED
}

model Order {
  id                String      @id @default(uuid()) @db.Uuid
  orderNumber       String      @unique
  customerId        String      @db.Uuid
  customerAddressId String      @db.Uuid
  deliveryZoneId    String?     @db.Uuid
  deliverySlotId    String?     @db.Uuid
  orderDate         DateTime
  deliveryDate      DateTime
  status            OrderStatus @default(DRAFT)
  paymentStatus     String      @default("UNPAID")

  subtotal            Decimal @db.Decimal(12, 2)
  orderDiscountAmount Decimal @default(0) @db.Decimal(10, 2)
  discountType        String? // Optional type like "PERCENTAGE" or "FIXED"
  taxableAmount       Decimal @default(0) @db.Decimal(12, 2)
  deliveryCharge      Decimal @default(0) @db.Decimal(10, 2)
  taxTotal            Decimal @default(0) @db.Decimal(10, 2)
  grandTotal          Decimal @db.Decimal(12, 2)

  taxInclusive  Boolean  @default(false)
  taxOnDelivery Boolean  @default(false)
  notes         String?
  isReplacement Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer        Customer        @relation(fields: [customerId], references: [id])
  customerAddress CustomerAddress @relation(fields: [customerAddressId], references: [id])
  deliveryZone    DeliveryZone?   @relation(fields: [deliveryZoneId], references: [id])
  deliverySlot    DeliverySlot?   @relation(fields: [deliverySlotId], references: [id])
  orderItems      OrderItem[]
  invoices        Invoice[]
}

model OrderItem {
  id                  String  @id @default(uuid()) @db.Uuid
  orderId             String  @db.Uuid
  productId           String  @db.Uuid
  productNameSnapshot String
  skuSnapshot         String
  quantity            Int
  unitPrice           Decimal @db.Decimal(10, 2)

  lineDiscountAmount Decimal @default(0) @db.Decimal(10, 2)
  taxableLineAmount  Decimal @default(0) @db.Decimal(12, 2)
  taxRateSnapshot    Decimal @db.Decimal(5, 2)
  taxAmount          Decimal @db.Decimal(10, 2)
  lineTotal          Decimal @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  invoiceNumber String        @unique
  orderId       String?       @db.Uuid
  customerId    String        @db.Uuid
  invoiceDate   DateTime
  dueDate       DateTime?
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(12, 2)
  discountTotal Decimal       @default(0) @db.Decimal(10, 2)
  taxTotal      Decimal       @default(0) @db.Decimal(10, 2)
  cgstTotal     Decimal       @default(0) @db.Decimal(10, 2)
  sgstTotal     Decimal       @default(0) @db.Decimal(10, 2)
  igstTotal     Decimal       @default(0) @db.Decimal(10, 2)
  placeOfSupply String? // GST State Code
  grandTotal    Decimal       @db.Decimal(12, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(12, 2)
  balanceDue    Decimal       @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order        Order?              @relation(fields: [orderId], references: [id])
  customer     Customer            @relation(fields: [customerId], references: [id])
  invoiceItems InvoiceItem[]
  allocations  PaymentAllocation[]
}

model InvoiceItem {
  id                  String  @id @default(uuid()) @db.Uuid
  invoiceId           String  @db.Uuid
  productId           String? @db.Uuid
  productNameSnapshot String
  skuSnapshot         String?
  quantity            Int
  unitPrice           Decimal @db.Decimal(10, 2)
  lineDiscountAmount  Decimal @default(0) @db.Decimal(10, 2)
  taxRateSnapshot     Decimal @db.Decimal(5, 2)
  taxAmount           Decimal @db.Decimal(10, 2)
  cgstAmount          Decimal @default(0) @db.Decimal(10, 2)
  sgstAmount          Decimal @default(0) @db.Decimal(10, 2)
  igstAmount          Decimal @default(0) @db.Decimal(10, 2)
  lineTotal           Decimal @db.Decimal(12, 2)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

enum PaymentMethod {
  CASH
  BANK
  RAZORPAY
}

enum PaymentStatus {
  DRAFT
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model CustomerPayment {
  id                String        @id @default(uuid()) @db.Uuid
  paymentNumber     String        @unique
  customerId        String        @db.Uuid
  paymentDate       DateTime
  amount            Decimal       @db.Decimal(12, 2)
  allocatedAmount   Decimal       @default(0) @db.Decimal(12, 2)
  unallocatedAmount Decimal       @default(0) @db.Decimal(12, 2)
  paymentMethod     PaymentMethod
  referenceNumber   String?
  notes             String?
  status            PaymentStatus @default(DRAFT)

  // Razorpay skeleton
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer    Customer            @relation(fields: [customerId], references: [id])
  allocations PaymentAllocation[]
}

model PaymentAllocation {
  id              String  @id @default(uuid()) @db.Uuid
  paymentId       String  @db.Uuid
  invoiceId       String  @db.Uuid
  allocatedAmount Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payment CustomerPayment @relation(fields: [paymentId], references: [id])
  invoice Invoice         @relation(fields: [invoiceId], references: [id])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum PostingStatus {
  DRAFT
  POSTED
  VOIDED
}

model Account {
  id          String      @id @default(uuid()) @db.Uuid
  code        String      @unique
  name        String
  type        AccountType
  isActive    Boolean     @default(true)
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  journalLines     JournalEntryLine[]
  Expense          Expense[]
  SupplierBillItem SupplierBillItem[]
  salesProducts    Product[]          @relation("ProductSalesAccount")
  purchaseProducts Product[]          @relation("ProductPurchaseAccount")
}

model JournalEntry {
  id            String        @id @default(uuid()) @db.Uuid
  journalNumber String        @unique
  entryDate     DateTime
  sourceType    String // e.g., "INVOICE", "CUSTOMER_PAYMENT"
  sourceId      String // e.g., the UUID of Invoice or Payment
  memo          String?
  status        PostingStatus @default(POSTED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lines JournalEntryLine[]

  @@unique([sourceType, sourceId]) // Enforce idempotency
}

model JournalEntryLine {
  id              String  @id @default(uuid()) @db.Uuid
  journalEntryId  String  @db.Uuid
  accountId       String  @db.Uuid
  debitAmount     Decimal @default(0) @db.Decimal(12, 2)
  creditAmount    Decimal @default(0) @db.Decimal(12, 2)
  lineDescription String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])
}

enum ExpenseStatus {
  DRAFT
  UNPAID
  PAID
  CANCELLED
}

model Expense {
  id                String        @id @default(uuid()) @db.Uuid
  expenseNumber     String        @unique
  expenseDate       DateTime
  expenseCategoryId String        @db.Uuid
  vendorId          String?       @db.Uuid
  amount            Decimal       @db.Decimal(12, 2)
  paymentAccountId  String?       @db.Uuid // if paid immediately, which bank/cash account
  notes             String?
  status            ExpenseStatus @default(DRAFT)
  paidImmediately   Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category       ExpenseCategory @relation(fields: [expenseCategoryId], references: [id])
  vendor         Vendor?         @relation(fields: [vendorId], references: [id])
  paymentAccount Account?        @relation(fields: [paymentAccountId], references: [id])
}

model VendorPaymentAllocation {
  id              String  @id @default(uuid()) @db.Uuid
  paymentId       String  @db.Uuid
  supplierBillId  String  @db.Uuid
  allocatedAmount Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payment      VendorPayment @relation(fields: [paymentId], references: [id])
  supplierBill SupplierBill  @relation(fields: [supplierBillId], references: [id])
}

enum SupplierBillStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model SupplierBill {
  id         String             @id @default(uuid()) @db.Uuid
  billNumber String             @unique
  vendorId   String             @db.Uuid
  billDate       DateTime
  dueDate        DateTime?
  reverseCharge  Boolean            @default(false)
  itcEligible    Boolean            @default(true)
  status     SupplierBillStatus @default(DRAFT)

  subtotal      Decimal @db.Decimal(12, 2)
  taxTotal      Decimal @default(0) @db.Decimal(10, 2)
  cgstTotal     Decimal @default(0) @db.Decimal(10, 2)
  sgstTotal     Decimal @default(0) @db.Decimal(10, 2)
  igstTotal     Decimal @default(0) @db.Decimal(10, 2)
  placeOfSupply String?
  grandTotal    Decimal @db.Decimal(12, 2)
  paidAmount    Decimal @default(0) @db.Decimal(12, 2)
  balanceDue    Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor      Vendor                    @relation(fields: [vendorId], references: [id])
  items       SupplierBillItem[]
  allocations VendorPaymentAllocation[]
}

model SupplierBillItem {
  id               String  @id @default(uuid()) @db.Uuid
  supplierBillId   String  @db.Uuid
  description      String
  quantity         Int?
  unitPrice        Decimal @db.Decimal(10, 2)
  taxRateSnapshot  Decimal @default(0) @db.Decimal(5, 2)
  taxAmount        Decimal @default(0) @db.Decimal(10, 2)
  cgstAmount       Decimal @default(0) @db.Decimal(10, 2)
  sgstAmount       Decimal @default(0) @db.Decimal(10, 2)
  igstAmount       Decimal @default(0) @db.Decimal(10, 2)
  lineTotal        Decimal @db.Decimal(12, 2)
  expenseAccountId String? @db.Uuid

  bill           SupplierBill @relation(fields: [supplierBillId], references: [id], onDelete: Cascade)
  expenseAccount Account?     @relation(fields: [expenseAccountId], references: [id])
}

enum VendorPaymentStatus {
  DRAFT
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model VendorPayment {
  id                String              @id @default(uuid()) @db.Uuid
  paymentNumber     String              @unique
  vendorId          String              @db.Uuid
  paymentDate       DateTime
  amount            Decimal             @db.Decimal(12, 2)
  allocatedAmount   Decimal             @default(0) @db.Decimal(12, 2)
  unallocatedAmount Decimal             @default(0) @db.Decimal(12, 2)
  paymentMethod     PaymentMethod
  referenceNumber   String?
  notes             String?
  status            VendorPaymentStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor      Vendor                    @relation(fields: [vendorId], references: [id])
  allocations VendorPaymentAllocation[]
}

// ── Razorpay Gateway Integration ──────────────────────────────────────────────

enum GatewayEventStatus {
  RECEIVED // webhook arrived but not yet processed
  PROCESSED // successfully mapped to CustomerPayment
  DUPLICATE // idempotency guard triggered — already processed
  IGNORED // event type we don't act on (e.g. refund, pending)
  FAILED // processing threw an error
}

model GatewayTransaction {
  id String @id @default(uuid()) @db.Uuid

  // Razorpay identifiers — razorpayEventId used as idempotency key
  razorpayEventId   String  @unique // X-Razorpay-Event-Id header
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  // Event metadata
  eventType       String // e.g. "payment.captured"
  status          GatewayEventStatus @default(RECEIVED)
  rawPayload      Json // full webhook body for audit
  processingError String? // error message if status = FAILED

  // Linked ERP records (set after successful processing)
  customerPaymentId String? @db.Uuid
  invoiceId         String? @db.Uuid

  // Amount in paise (Razorpay native) and INR
  amountPaise Int?
  amountInr   Decimal? @db.Decimal(12, 2)
  currency    String?  @default("INR")

  // Merchant notes / metadata passed at order creation
  notes Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── WhatsApp Notification Integration ────────────────────────────────────────

enum WhatsappMessageStatus {
  SIMULATED
  QUEUED
  SENT
  DELIVERED
  FAILED
}

model WhatsappMessageLog {
  id                String                @id @default(uuid()) @db.Uuid
  customerId        String?               @db.Uuid
  phone             String
  templateName      String
  linkedEntityType  String? // e.g. 'ORDER', 'INVOICE', 'PAYMENT'
  linkedEntityId    String?               @db.Uuid
  payload           Json?
  providerMessageId String?
  status            WhatsappMessageStatus @default(QUEUED)
  errorReason       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
}
