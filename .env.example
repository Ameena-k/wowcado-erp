# ==========================================
# Wowcado - Internal Pilot Environment Set
# ==========================================

# ─── 1. CORE API & DATABASE ───────────────
NODE_ENV="development" # Set to "production" in Railway
PORT=3001
# The Prisma ORM Connection String (Railway provides this as DATABASE_URL inherently)
DATABASE_URL="postgresql://root:password@localhost:5432/wowcado_erp?schema=public"

# MUST set in production to prevent hard-coded fallbacks
JWT_SECRET="changeme_to_a_secure_128_bit_random_string"

# ─── 2. CORS & FRONTEND ROUTING ───────────
# Where the backend allows requests FROM (Your Vercel deployment URL)
FRONTEND_URL="http://localhost:3000"

# Where your local/deployed NextJS points TO (Your Railway URL)
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# ─── 3. EXTERNAL INTEGRATIONS ─────────────
# Razorpay Testing / Production Keys
RAZORPAY_KEY_ID="rzp_test_YourKeyID"
RAZORPAY_KEY_SECRET="YourKeySecretString"
# Secret for authorizing incoming Webhooks (Configure in Razorpay Dashboard)
RAZORPAY_WEBHOOK_SECRET="secure_webhook_secret_string"

